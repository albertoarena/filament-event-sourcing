{
    "name": "albertoarena/filament-event-sourcing",
    "description": "Bridge spatie/laravel-event-sourcing v7 with Filament admin panels: write through aggregates, audit stored events, and replay projectors.",
    "keywords": [
        "laravel",
        "filament",
        "event-sourcing",
        "spatie",
        "cqrs",
        "aggregates"
    ],
    "homepage": "https://albertoarena.github.io/filament-event-sourcing",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/albertoarena/filament-event-sourcing/issues",
        "source": "https://github.com/albertoarena/filament-event-sourcing",
        "docs": "https://albertoarena.github.io/filament-event-sourcing"
    },
    "authors": [
        {
            "name": "Alberto Arena",
            "email": "arena.alberto@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "filament/filament": "^4.0",
        "spatie/laravel-event-sourcing": "^7.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.17",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Albertoarena\\FilamentEventSourcing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Albertoarena\\FilamentEventSourcing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --min=90",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Albertoarena\\FilamentEventSourcing\\FilamentEventSourcingServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
