---
const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = (path) => `${base.replace(/\/$/, '')}/${path}`.replace(/\/+$/, '') || base;

const current = Astro.url.pathname.replace(/\/$/, '');
const isActive = (path) => current === href(path).replace(/\/$/, '');

const nav = [
  { label: 'Overview', path: '' },
  { label: 'Installation', path: 'installation' },
  { label: 'Write bridge', path: 'write-bridge' },
  { label: 'Audit tooling', path: 'audit-tooling' },
  { label: 'Replay page', path: 'replay-page' },
  { label: 'Configuration', path: 'configuration' },
];

const title = frontmatter?.title ?? 'Filament Event Sourcing';
const description = frontmatter?.description ?? 'Integrate spatie/laravel-event-sourcing with Filament admin panels.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Filament Event Sourcing</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="shell">
      <aside class="sidebar">
        <a class="brand" href={href('')}>Filament Event Sourcing</a>
        <nav aria-label="Documentation">
          <ul>
            {nav.map((item) => (
              <li>
                <a href={href(item.path)} aria-current={isActive(item.path) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <a class="repo" href="https://github.com/albertoarena/filament-event-sourcing">View on GitHub</a>
      </aside>

      <main id="content" class="content">
        <article>
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f1115;
    --surface: #171a21;
    --border: #262b36;
    --text: #e6e8ec;
    --muted: #9aa3b2;
    --accent: #f59e0b;
    --code-bg: #0b0d11;
    --radius: 10px;
    --max: 760px;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
  }

  .skip-link {
    position: absolute;
    left: -999px;
  }
  .skip-link:focus {
    left: 1rem;
    top: 1rem;
    background: var(--surface);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
  }

  .shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
  }

  .sidebar {
    border-right: 1px solid var(--border);
    padding: 2rem 1.5rem;
    background: var(--surface);
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .brand {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text);
    text-decoration: none;
  }

  .sidebar nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar nav a {
    display: block;
    padding: 0.4rem 0.6rem;
    border-radius: 8px;
    color: var(--muted);
    text-decoration: none;
  }
  .sidebar nav a:hover { color: var(--text); background: rgba(255, 255, 255, 0.04); }
  .sidebar nav a[aria-current='page'] {
    color: var(--text);
    background: rgba(245, 158, 11, 0.12);
    box-shadow: inset 2px 0 0 var(--accent);
  }

  .repo {
    margin-top: auto;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .repo:hover { color: var(--text); }

  .content { padding: 3rem 2rem; }

  article {
    max-width: var(--max);
    margin: 0 auto;
  }

  article h1 { font-size: 2rem; line-height: 1.2; margin: 0 0 1rem; }
  article h2 { font-size: 1.35rem; margin: 2.5rem 0 0.75rem; }
  article h3 { font-size: 1.1rem; margin: 1.75rem 0 0.5rem; }

  article a { color: var(--accent); }

  article p, article li { color: var(--text); }

  article code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.9em;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.1rem 0.35rem;
  }

  article pre {
    background: var(--code-bg) !important;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
    overflow-x: auto;
  }
  article pre code {
    background: transparent;
    border: 0;
    padding: 0;
  }

  .callout {
    border: 1px solid rgba(245, 158, 11, 0.35);
    background: rgba(245, 158, 11, 0.08);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
    margin: 1.5rem 0;
  }
  .callout strong { color: var(--accent); }

  @media (max-width: 820px) {
    .shell { grid-template-columns: 1fr; }
    .sidebar { position: static; height: auto; }
  }
</style>
